---
// src/components/ArticleTOC.astro
// Sticky sidebar table of contents for long articles
// Auto-generates from H2/H3 headings, highlights current section on scroll
// Desktop: fixed sidebar on the right
// Mobile: floating "Contents" button with dropdown
---

<style is:global>
  /* Desktop TOC sidebar */
  .pgb-toc {
    position: fixed;
    top: 5rem;
    width: 220px;
    max-height: calc(100vh - 7rem);
    overflow-y: auto;
    font-size: 0.8125rem;
    line-height: 1.4;
    z-index: 20;
    /* Hide scrollbar but keep scrollable */
    scrollbar-width: thin;
    scrollbar-color: var(--color-border) transparent;
  }
  .pgb-toc::-webkit-scrollbar {
    width: 3px;
  }
  .pgb-toc::-webkit-scrollbar-thumb {
    background: var(--color-border);
    border-radius: 3px;
  }

  .pgb-toc__title {
    font-size: 0.6875rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--color-text-muted);
    margin: 0 0 0.625rem;
    padding: 0 0.5rem;
  }

  .pgb-toc__list {
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .pgb-toc__item {
    margin: 0;
  }

  .pgb-toc__link {
    display: block;
    padding: 0.25rem 0.5rem;
    color: var(--color-text-muted);
    text-decoration: none;
    border-left: 2px solid transparent;
    border-radius: 0 4px 4px 0;
    transition: color 0.15s ease, border-color 0.15s ease, background 0.15s ease;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .pgb-toc__link:hover {
    color: var(--color-text-primary);
    background: color-mix(in srgb, var(--color-accent-blue) 5%, transparent);
  }

  .pgb-toc__link--active {
    color: var(--color-accent-blue);
    border-left-color: var(--color-accent-blue);
    font-weight: 500;
  }

  .pgb-toc__link--h3 {
    padding-left: 1.25rem;
    font-size: 0.75rem;
  }

  /* Hide on screens too narrow for sidebar */
  @media (max-width: 1280px) {
    .pgb-toc {
      display: none;
    }
  }

  /* Mobile floating button */
  .pgb-toc-mobile {
    display: none;
    position: fixed;
    bottom: 1.5rem;
    right: 1.5rem;
    z-index: 30;
  }

  @media (max-width: 1280px) {
    .pgb-toc-mobile {
      display: block;
    }
  }

  .pgb-toc-mobile__btn {
    display: flex;
    align-items: center;
    gap: 0.375rem;
    padding: 0.5rem 0.875rem;
    font-size: 0.8125rem;
    font-weight: 600;
    background: var(--color-bg-card);
    color: var(--color-text-primary);
    border: 1px solid var(--color-border);
    border-radius: 999px;
    cursor: pointer;
    box-shadow: 0 2px 12px rgba(0, 0, 0, 0.1);
    transition: box-shadow 0.15s ease;
  }

  .pgb-toc-mobile__btn:hover {
    box-shadow: 0 4px 16px rgba(0, 0, 0, 0.15);
  }

  .pgb-toc-mobile__dropdown {
    display: none;
    position: absolute;
    bottom: calc(100% + 0.5rem);
    right: 0;
    width: 260px;
    max-height: 60vh;
    overflow-y: auto;
    background: var(--color-bg-card);
    border: 1px solid var(--color-border);
    border-radius: 12px;
    box-shadow: 0 4px 20px rgba(0, 0, 0, 0.12);
    padding: 0.75rem 0;
  }

  .pgb-toc-mobile__dropdown--open {
    display: block;
  }

  .pgb-toc-mobile__dropdown .pgb-toc__link {
    padding: 0.375rem 1rem;
    border-left: none;
    white-space: normal;
  }

  .pgb-toc-mobile__dropdown .pgb-toc__link--h3 {
    padding-left: 1.75rem;
  }

  .pgb-toc-mobile__dropdown .pgb-toc__link--active {
    background: color-mix(in srgb, var(--color-accent-blue) 8%, transparent);
  }
</style>

<script>
(function() {
  const article = document.querySelector('article.prose');
  if (!article) return;

  const headings = article.querySelectorAll('h2, h3');
  if (headings.length < 3) return; // Don't show TOC for very short articles

  // Ensure all headings have IDs (Astro markdown usually adds them)
  headings.forEach((h, i) => {
    if (!h.id) {
      h.id = 'heading-' + i;
    }
  });

  // Build TOC items
  const items: Array<{id: string; text: string; level: number}> = [];
  headings.forEach((h) => {
    // Skip the Sources heading and anything after it
    if (h.textContent?.trim().match(/^(Sources|参考来源|来源)/)) return;
    items.push({
      id: h.id,
      text: (h.textContent || '').replace(/💬/g, '').trim(),
      level: h.tagName === 'H3' ? 3 : 2,
    });
  });

  if (items.length < 3) return;

  // Create desktop sidebar TOC
  const toc = document.createElement('nav');
  toc.className = 'pgb-toc';
  toc.setAttribute('aria-label', 'Table of contents');

  // Position it to the right of the content area
  function positionTOC() {
    const contentEl = document.querySelector('.article-page');
    if (!contentEl) return;
    const rect = contentEl.getBoundingClientRect();
    const rightEdge = rect.right + 32; // 32px gap
    toc.style.left = rightEdge + 'px';
  }

  const titleEl = document.createElement('p');
  titleEl.className = 'pgb-toc__title';
  titleEl.textContent = document.documentElement.lang === 'zh-Hans' ? '目录' : 'Contents';
  toc.appendChild(titleEl);

  const list = document.createElement('ul');
  list.className = 'pgb-toc__list';

  items.forEach((item) => {
    const li = document.createElement('li');
    li.className = 'pgb-toc__item';
    const a = document.createElement('a');
    a.className = 'pgb-toc__link' + (item.level === 3 ? ' pgb-toc__link--h3' : '');
    a.href = '#' + item.id;
    a.textContent = item.text;
    a.addEventListener('click', (e) => {
      e.preventDefault();
      document.getElementById(item.id)?.scrollIntoView({ behavior: 'smooth', block: 'start' });
      // Close mobile dropdown if open
      const dropdown = document.querySelector('.pgb-toc-mobile__dropdown');
      if (dropdown) dropdown.classList.remove('pgb-toc-mobile__dropdown--open');
    });
    li.appendChild(a);
    list.appendChild(li);
  });

  toc.appendChild(list);
  document.body.appendChild(toc);

  // Create mobile floating button
  const mobile = document.createElement('div');
  mobile.className = 'pgb-toc-mobile';
  mobile.innerHTML = `
    <button class="pgb-toc-mobile__btn" aria-label="Table of contents">
      <span>☰</span>
      <span>${document.documentElement.lang === 'zh-Hans' ? '目录' : 'Contents'}</span>
    </button>
    <div class="pgb-toc-mobile__dropdown"></div>
  `;

  const dropdown = mobile.querySelector('.pgb-toc-mobile__dropdown')!;
  // Clone the list for mobile
  const mobileList = list.cloneNode(true) as HTMLElement;
  mobileList.querySelectorAll('a').forEach((a, i) => {
    a.addEventListener('click', (e) => {
      e.preventDefault();
      document.getElementById(items[i].id)?.scrollIntoView({ behavior: 'smooth', block: 'start' });
      dropdown.classList.remove('pgb-toc-mobile__dropdown--open');
    });
  });
  dropdown.appendChild(mobileList);

  mobile.querySelector('.pgb-toc-mobile__btn')!.addEventListener('click', () => {
    dropdown.classList.toggle('pgb-toc-mobile__dropdown--open');
  });

  // Close dropdown when clicking outside
  document.addEventListener('click', (e) => {
    if (!mobile.contains(e.target as Node)) {
      dropdown.classList.remove('pgb-toc-mobile__dropdown--open');
    }
  });

  document.body.appendChild(mobile);

  // Highlight current section on scroll (Intersection Observer)
  const observer = new IntersectionObserver(
    (entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          const id = entry.target.id;
          // Update desktop TOC
          toc.querySelectorAll('.pgb-toc__link').forEach((link) => {
            link.classList.toggle('pgb-toc__link--active', link.getAttribute('href') === '#' + id);
          });
          // Update mobile dropdown
          dropdown.querySelectorAll('.pgb-toc__link').forEach((link) => {
            link.classList.toggle('pgb-toc__link--active', link.getAttribute('href') === '#' + id);
          });
        }
      });
    },
    {
      rootMargin: '-80px 0px -70% 0px',
      threshold: 0,
    }
  );

  headings.forEach((h) => {
    if (items.some(item => item.id === h.id)) {
      observer.observe(h);
    }
  });

  // Position on load and resize
  positionTOC();
  window.addEventListener('resize', positionTOC);
  window.addEventListener('scroll', positionTOC, { passive: true });
})();
</script>

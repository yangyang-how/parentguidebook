---
import { getCollection } from 'astro:content';
import type { Lang } from '../../../../i18n/ui';
import { useTranslations } from '../../../../i18n/utils';
import BaseLayout from '../../../../layouts/BaseLayout.astro';
import { getReadyDomains, DOMAINS_BY_CATEGORY } from '../../../../config/domains';
import { getArticlePath, getDomainPath, getBaseSlugFromId } from '../../../../utils/routes';

export async function getStaticPaths() {
  const ready = getReadyDomains();
  const paths: { params: { lang: string; category: string; domain: string } }[] = [];
  for (const lang of ['en', 'zh']) {
    for (const d of ready) {
      paths.push({ params: { lang, category: d.category, domain: d.slug } });
    }
  }
  return paths;
}

const { lang, category, domain } = Astro.params as { lang: Lang; category: string; domain: string };
const t = useTranslations(lang);
const canonicalPath = getDomainPath(lang, category, domain);

// Find the domain label from config
const domainConfig = (DOMAINS_BY_CATEGORY[category as keyof typeof DOMAINS_BY_CATEGORY] ?? [])
  .find((d) => d.slug === domain);
const domainLabel = domainConfig ? t(domainConfig.labelKey as any) : domain;

const all = await getCollection('articles');
const articles = all
  .filter((e) => e.data.domain === domain)
  .filter((e) => (lang === 'en' ? e.data.lang === 'en' : e.data.lang === 'zh-Hans'))
  .sort((a, b) => a.data.title.localeCompare(b.data.title));

// Group articles by their subcategory
const subcategories = [...new Set(articles.map((a) => a.data.category))];
const bySubcategory = Object.fromEntries(
  subcategories.map((cat) => [cat, articles.filter((a) => a.data.category === cat)])
);
---

<BaseLayout
  lang={lang}
  title={`${domainLabel} · Parent Guidebook`}
  description={`${domainLabel} — Parent Guidebook`}
  canonicalPath={canonicalPath}
>
  <section class="landing-hero">
    <h1 class="landing-hero__title">{domainLabel}</h1>
  </section>

  <section class="landing-section">
    <h2 class="landing-section__title">{t('landing.featured.title')}</h2>
    <div class="landing-grid">
      {Object.entries(bySubcategory).map(([cat, list]) => (
        <div class="landing-category">
          <h3 class="landing-category__title">{t(`category.${cat}` as any)}</h3>
          <div class="landing-cards">
            {list.map((a) => (
              <a class="landing-card" href={getArticlePath(lang, a)}>
                <div class="landing-card__category">{t(`category.${a.data.category}` as any)}</div>
                <div class="landing-card__title">{a.data.title}</div>
                <div class="landing-card__meta">{t(`urgency.${a.data.urgency}` as any)}</div>
              </a>
            ))}
          </div>
        </div>
      ))}
    </div>
  </section>
</BaseLayout>

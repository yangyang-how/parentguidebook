---
// src/components/CommentSystem.astro
// No server-side props needed — all behavior is client-side
---

<style is:global>
  .pgb-comment-icon {
    position: absolute;
    right: -2.5rem;
    top: 0.125rem;
    width: 1.5rem;
    height: 1.5rem;
    cursor: pointer;
    opacity: 0;
    transition: opacity 0.15s ease;
    font-size: 0.875rem;
    line-height: 1.5rem;
    text-align: center;
    color: var(--color-text-muted);
    user-select: none;
    z-index: 10;
  }
  .pgb-comment-icon:hover {
    color: var(--color-accent-blue);
  }
  /* Show on hover (desktop) */
  [data-pgb-commentable]:hover .pgb-comment-icon {
    opacity: 1;
  }
  /* Always show on mobile — position inline at end of paragraph */
  @media (max-width: 768px) {
    .pgb-comment-icon {
      position: static;
      display: inline;
      opacity: 0;
      margin-left: 0.25rem;
    }
    [data-pgb-commentable]:hover .pgb-comment-icon,
    .pgb-comment-icon[data-has-comments] {
      opacity: 0.6;
    }
  }
  /* Always show if paragraph has comments */
  .pgb-comment-icon[data-has-comments] {
    opacity: 1;
  }

  .pgb-comment-badge {
    background: var(--color-accent-blue);
    color: #fff;
    font-size: 0.625rem;
    font-weight: 600;
    border-radius: 999px;
    min-width: 0.875rem;
    height: 0.875rem;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 0 0.25rem;
    position: absolute;
    top: -0.375rem;
    right: -0.5rem;
    pointer-events: none;
  }

  /* Wrapper for paragraph + sidebar comment form */
  .pgb-comment-row {
    display: flex;
    align-items: flex-start;
    gap: 1rem;
  }
  .pgb-comment-row > :first-child {
    flex: 1;
    min-width: 0;
  }

  .pgb-comment-form {
    width: 280px;
    flex-shrink: 0;
    padding: 0.875rem;
    border: 1px solid var(--color-border);
    border-radius: 10px;
    background: var(--color-bg-card);
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.06);
  }
  /* On mobile, form goes below the paragraph */
  @media (max-width: 768px) {
    .pgb-comment-row {
      flex-direction: column;
    }
    .pgb-comment-form {
      width: 100%;
    }
  }
  .pgb-comment-form textarea {
    width: 100%;
    min-height: 4rem;
    padding: 0.5rem 0.625rem;
    border: 1px solid var(--color-border);
    border-radius: 8px;
    background: var(--color-bg-primary);
    color: var(--color-text-primary);
    font-family: inherit;
    font-size: 0.8125rem;
    line-height: 1.5;
    resize: vertical;
    outline: none;
  }
  .pgb-comment-form textarea:focus {
    border-color: var(--color-accent-blue);
    box-shadow: 0 0 0 2px rgba(91, 155, 213, 0.12);
  }
  .pgb-comment-form-actions {
    display: flex;
    justify-content: flex-end;
    gap: 0.5rem;
    margin-top: 0.5rem;
  }
  .pgb-comment-form button {
    padding: 0.4rem 0.875rem;
    font-size: 0.8125rem;
    font-weight: 600;
    border-radius: 8px;
    cursor: pointer;
    transition: background 0.1s ease, border-color 0.1s ease;
  }
  .pgb-comment-form button.pgb-cancel {
    background: var(--color-bg-secondary);
    color: var(--color-text-secondary);
    border: 1px solid var(--color-border);
  }
  .pgb-comment-form button.pgb-cancel:hover {
    background: var(--color-bg-primary);
    border-color: var(--color-text-muted);
  }
  .pgb-comment-form button[type="submit"] {
    background: var(--color-accent-blue);
    color: #fff;
    border: 1px solid var(--color-accent-blue);
  }
  .pgb-comment-form button[type="submit"]:hover {
    filter: brightness(1.08);
  }
  .pgb-comment-form button[type="submit"]:disabled {
    opacity: 0.6;
    cursor: not-allowed;
  }
  .pgb-comment-form .pgb-error {
    color: var(--color-urgency-critical);
    font-size: 0.75rem;
    margin-top: 0.375rem;
  }

  .pgb-comments-list {
    width: 280px;
    flex-shrink: 0;
    padding: 0;
    list-style: none;
  }
  @media (max-width: 768px) {
    .pgb-comments-list {
      width: 100%;
    }
  }
  .pgb-comment-item {
    padding: 0.625rem 0.75rem;
    border: 1px solid var(--color-border);
    border-radius: 8px;
    background: var(--color-bg-card);
    margin-bottom: 0.375rem;
    font-size: 0.8125rem;
    box-shadow: 0 1px 4px rgba(0, 0, 0, 0.04);
  }
  .pgb-comment-item__header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 0.25rem;
  }
  .pgb-comment-item__name {
    font-weight: 600;
    font-size: 0.75rem;
    color: var(--color-accent-blue);
  }
  .pgb-comment-item__date {
    font-size: 0.6875rem;
    color: var(--color-text-muted);
  }
  .pgb-comment-item__text {
    color: var(--color-text-secondary);
    line-height: 1.5;
  }
</style>

<script>
(function() {
  const SELECTORS = 'main .prose p, main .prose li, main .prose h2, main .prose h3, main .prose h4, main .prose blockquote';
  const pagePath = window.location.pathname.endsWith('/') ? window.location.pathname : window.location.pathname + '/';
  let allComments: Array<{id: number; paragraph_id: string; reviewer_name: string; comment_text: string; created_at: string}> = [];

  function escapeHtml(s: string): string {
    const d = document.createElement('div');
    d.textContent = s;
    return d.innerHTML;
  }

  function assignParagraphIds() {
    const counts: Record<string, number> = {};
    document.querySelectorAll(SELECTORS).forEach((el) => {
      const tag = el.tagName.toLowerCase();
      counts[tag] = (counts[tag] || 0);
      const id = `${tag}-${counts[tag]}`;
      counts[tag]++;
      el.setAttribute('data-pgb-id', id);
      el.setAttribute('data-pgb-commentable', '');
      (el as HTMLElement).style.position = 'relative';

      // Add comment icon — positioned to the right
      const icon = document.createElement('span');
      icon.className = 'pgb-comment-icon';
      icon.textContent = '💬';
      icon.setAttribute('data-pgb-trigger', id);
      icon.addEventListener('click', (e) => {
        e.stopPropagation();
        togglePanel(id, el as HTMLElement);
      });
      el.appendChild(icon);
    });
  }

  function getCommentsForParagraph(paragraphId: string) {
    return allComments.filter(c => c.paragraph_id === paragraphId);
  }

  function togglePanel(paragraphId: string, el: HTMLElement) {
    // If already open, close it
    const existingRow = el.closest('.pgb-comment-row') || el.parentElement?.querySelector(`.pgb-comment-row[data-for="${paragraphId}"]`);
    if (existingRow) {
      const original = existingRow.querySelector('[data-pgb-commentable]');
      if (original) existingRow.replaceWith(original);
      return;
    }

    // Close any other open panels
    document.querySelectorAll('.pgb-comment-row').forEach(row => {
      const original = row.querySelector('[data-pgb-commentable]');
      if (original) row.replaceWith(original);
    });

    const preview = (el.textContent || '').slice(0, 80);
    const comments = getCommentsForParagraph(paragraphId);

    // Create row: [paragraph] [panel]
    const row = document.createElement('div');
    row.className = 'pgb-comment-row';
    row.setAttribute('data-for', paragraphId);

    el.parentElement!.insertBefore(row, el);
    row.appendChild(el);

    // Create unified panel (existing comments + form)
    const panel = document.createElement('div');
    panel.className = 'pgb-comment-form';

    // Render existing comments inside the panel
    let commentsHtml = '';
    if (comments.length > 0) {
      commentsHtml = '<ul class="pgb-comments-list" style="width:100%;margin:0 0 0.75rem;">';
      for (const c of comments) {
        const date = new Date(c.created_at + 'Z').toLocaleDateString(undefined, { month: 'short', day: 'numeric', year: 'numeric' });
        commentsHtml += `
          <li class="pgb-comment-item">
            <div class="pgb-comment-item__header">
              <span class="pgb-comment-item__name">${escapeHtml(c.reviewer_name)}</span>
              <span class="pgb-comment-item__date">${date}</span>
            </div>
            <div class="pgb-comment-item__text">${escapeHtml(c.comment_text)}</div>
          </li>`;
      }
      commentsHtml += '</ul>';
    }

    panel.innerHTML = `
      ${commentsHtml}
      <textarea placeholder="Leave your feedback..." maxlength="2000"></textarea>
      <div class="pgb-comment-form-actions">
        <button type="button" class="pgb-cancel">Cancel</button>
        <button type="submit">Submit</button>
      </div>
    `;

    panel.querySelector('.pgb-cancel')!.addEventListener('click', () => {
      row.replaceWith(el);
    });

    panel.querySelector('button[type="submit"]')!.addEventListener('click', async () => {
      const textarea = panel.querySelector('textarea')!;
      const text = textarea.value.trim();
      if (!text) return;
      const submitBtn = panel.querySelector('button[type="submit"]') as HTMLButtonElement;
      submitBtn.disabled = true;
      submitBtn.textContent = 'Saving...';

      try {
        const res = await fetch('/api/comments', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({
            page_path: pagePath,
            paragraph_id: paragraphId,
            paragraph_preview: preview,
            comment_text: text,
          }),
        });
        if (res.status === 401) {
          const errDiv = panel.querySelector('.pgb-error') || document.createElement('div');
          errDiv.className = 'pgb-error';
          errDiv.textContent = 'You need a contributor passkey to leave feedback.';
          panel.querySelector('.pgb-comment-form-actions')!.before(errDiv);
          submitBtn.disabled = false;
          submitBtn.textContent = 'Submit';
          return;
        }
        if (!res.ok) throw new Error('Failed');
        row.replaceWith(el);
        await loadComments();
      } catch {
        const errDiv = panel.querySelector('.pgb-error') || document.createElement('div');
        errDiv.className = 'pgb-error';
        errDiv.textContent = 'Comment failed to save — try again.';
        panel.querySelector('.pgb-comment-form-actions')!.before(errDiv);
        submitBtn.disabled = false;
        submitBtn.textContent = 'Submit';
      }
    });

    row.appendChild(panel);
    panel.querySelector('textarea')!.focus();
  }

  function renderComments() {
    // Remove old badges
    document.querySelectorAll('.pgb-comment-badge').forEach(b => b.remove());

    // Group by paragraph
    const grouped: Record<string, typeof allComments> = {};
    for (const c of allComments) {
      (grouped[c.paragraph_id] ||= []).push(c);
    }

    for (const [pid, comments] of Object.entries(grouped)) {
      const el = document.querySelector(`[data-pgb-id="${pid}"]`);
      if (!el) continue;

      const icon = el.querySelector('.pgb-comment-icon');
      if (icon) {
        icon.setAttribute('data-has-comments', '');
        // Add count badge on the icon (non-clickable, just visual)
        const badge = document.createElement('span');
        badge.className = 'pgb-comment-badge';
        badge.textContent = comments.length.toString();
        icon.appendChild(badge);
      }
    }
  }

  async function loadComments() {
    try {
      const res = await fetch(`/api/comments?page=${encodeURIComponent(pagePath)}`);
      if (!res.ok) return;
      allComments = await res.json();
      renderComments();
    } catch {
      // Silently fail — don't break reading experience
    }
  }

  // Initialize
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', () => { assignParagraphIds(); loadComments(); });
  } else {
    assignParagraphIds();
    loadComments();
  }
})();
</script>
